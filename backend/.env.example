# Backend Configuration
PORT=4000

# Pinata IPFS Integration
# Get your JWT from https://pinata.cloud
# Leave empty to use mock mode (for development)
PINATA_JWT=

# Optional: Pinata API Key and Secret (alternative to JWT)
# PINATA_API_KEY=
# PINATA_API_SECRET=

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Database
DATABASE_PATH=backend/data/scholarpass.db
